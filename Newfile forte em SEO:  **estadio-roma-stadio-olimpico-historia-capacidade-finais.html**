<script>
  const CATEGORY_SLUG = "futebol";
  const CATEGORY_NAME = "Futebol";

  const AGENDA_JSON_URL = "agenda.json";

  function escapeHtml(str) {
    return String(str || "").replace(/[&<>"']/g, s => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;"
    }[s]));
  }

  // Categoria
  const categoryLink = document.getElementById("categoryLink");
  categoryLink.textContent = CATEGORY_NAME;
  categoryLink.href = CATEGORY_SLUG + ".html";

  // Menu ativo
  const menuLinks = document.querySelectorAll("#sportsMenu a");
  menuLinks.forEach(a => {
    if (a.dataset.slug === CATEGORY_SLUG) a.classList.add("active");
  });

  // Agenda automática
  function renderAgenda(items) {
    const list = document.getElementById("agendaList");

    if (!items.length) {
      list.innerHTML = `
        <li>
          <div class="time">--:--</div>
          <div class="desc">Agenda ainda não cadastrada.</div>
        </li>
      `;
      return;
    }

    const ordered = items.slice().sort((a,b) => {
      const ta = String(a.time || "").trim();
      const tb = String(b.time || "").trim();
      return ta.localeCompare(tb);
    });

    list.innerHTML = ordered.slice(0, 12).map(it => `
      <li>
        <div class="time">${escapeHtml(it.time || "--:--")}</div>
        <div class="desc">${escapeHtml(it.desc || "")}</div>
      </li>
    `).join("");
  }

  async function loadAgenda() {
    try {
      const res = await fetch(AGENDA_JSON_URL, { cache: "no-store" });
      if (!res.ok) throw new Error("Falha ao carregar agenda.json");
      const data = await res.json();

      const items = Array.isArray(data) ? data : (Array.isArray(data.items) ? data.items : []);
      const clean = items
        .filter(x => x && (x.time || x.desc))
        .map(x => ({
          time: String(x.time || "").trim(),
          desc: String(x.desc || "").trim()
        }));

      renderAgenda(clean);
    } catch (e) {
      document.getElementById("agendaList").innerHTML = `
        <li>
          <div class="time">--:--</div>
          <div class="desc">Erro ao carregar agenda.</div>
        </li>
      `;
    }
  }

  loadAgenda();
</script>

